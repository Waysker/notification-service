# Spektakle monitorowane (oddzielone przecinkami)
MONITORED_PLAYS=Dziady,Wesele

# URL oficjalnego repertuaru
THEATER_REPERTUAR_URL=https://teatrwkrakowie.pl/repertuar

# Szablon URL listy terminów w systemie biletowym
THEATER_TICKET_PAGE_TEMPLATE=https://bilety.teatrwkrakowie.pl/index.php/bilety/{slug}

# Slugi spektakli (możesz dopasować)
PLAY_SLUG_DZIADY=dziady
PLAY_SLUG_WESELE=wesele

# Dodatkowe źródło: Biletomat
ENABLE_BILETOMAT=true
BILETOMAT_URL_DZIADY=https://biletomat.pl/wydarzenia/dziady-15362
BILETOMAT_URL_WESELE=https://biletomat.pl/wydarzenia/wesele-slowacki-22040

# Dodatkowe źródło: Facebook Graph API (oficjalne API)
# Uwaga: wymagany token + uprawnienia. Dla grup zwykle potrzebna zgoda app review Meta.
ENABLE_FACEBOOK=false
FACEBOOK_GRAPH_BASE_URL=https://graph.facebook.com
FACEBOOK_GRAPH_VERSION=v25.0
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_GROUP_ID=
FACEBOOK_KEYWORDS_INCLUDE=Dziady,Wesele
FACEBOOK_KEYWORDS_EXCLUDE=koncert,festiwal,szkolenie,standup
FACEBOOK_MAX_POSTS=25

# Interwał pętli `watch` (sekundy)
CHECK_INTERVAL_SECONDS=180

# Smoke checki
SMOKE_NOTIFY_ON_SUCCESS=false
SMOKE_NOTIFY_ON_FAILURE=true

# ntfy (PRIMARY notifier)
# Dla publicznego serwera wystarczy losowy temat w NTFY_TOPIC.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
NTFY_USERNAME=
NTFY_PASSWORD=
NTFY_PRIORITY_ALERTS=high
NTFY_PRIORITY_SMOKE_SUCCESS=default
NTFY_PRIORITY_SMOKE_FAILURE=urgent
NTFY_TAGS_ALERTS=ticket,theatre
NTFY_TAGS_SMOKE=warning,monitoring

# Signal (opcjonalny fallback)
# Wymaga zainstalowanego signal-cli i zarejestrowanego konta.
SIGNAL_CLI_PATH=signal-cli
SIGNAL_ACCOUNT=
SIGNAL_RECIPIENTS=
SIGNAL_TIMEOUT_SECONDS=30

# Email (fallback)
# EMAIL_FALLBACK_ON_TICKET_ALERTS=false => brak fallbacku email dla zwykłych alertów biletowych
# (email nadal można używać dla smoke-check i testów).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=[bilety]
EMAIL_FALLBACK_ON_TICKET_ALERTS=false

# HTTP
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36

# Stan lokalny
STATE_DB_PATH=./data/state.sqlite3

# Telegram (opcjonalny fallback)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
